# Zano Bridge — local dev configuration
#
# The bridge does not auto-load this file. If you want to use it, source it
# in your shell before starting the bridge:
#
#   set -a
#   source apps/bridge/.env
#   set +a
#   pnpm --filter ./apps/bridge dev -- --server-url http://localhost:3000
#
# --server-url is required and must be passed explicitly.

ZANO_API_KEY=zk_your_machine_key_here
ZANO_AGENTS_DIR=~/.zano/agents
